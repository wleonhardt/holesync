# holesync configuration — copy to /etc/holesync/holesync.conf and chmod 600.
# Secrets live in this file, so keep it out of version control.

# Passwords: if a Pi-hole has 2FA enabled, its plain admin password will NOT
# authenticate over the API — create an *application password* (web UI:
# Settings -> Web interface / API -> App password) and use that instead. App
# passwords also survive an admin-password change and are the documented
# automation credential. Prefer password_file to keep the secret out of this file.

# The authoritative Pi-hole. holesync reads from here and never writes to it.
[source]
url = http://10.0.0.10
password = CHANGEME
# password_file = /etc/holesync/source.pw   ; alternative to inline password

# One [replica:<name>] section per Pi-hole to keep in sync with the source.
[replica:pihole-02]
url = http://10.0.0.11
password = CHANGEME
# password_file = /etc/holesync/pihole-02.pw

# Add more replicas freely:
# [replica:pihole-03]
# url = http://10.0.0.12
# password = CHANGEME

[sync]
# Local DNS (config API — instant in-place reload, zero DNS downtime):
hosts = true          ; local A/AAAA records (dns.hosts)
cnames = true         ; local CNAMEs (dns.cnameRecords)

# Gravity-database collections (optional). Groups are pulled in automatically
# when adlists/domains are enabled, because those reference groups (holesync
# remaps group ids by name across Pi-holes).
groups = false        ; filtering groups
adlists = false       ; blocklist/allowlist URLs (the adlist definitions)
domains = false       ; allow/deny exact+regex domains (auto-apply, no rebuild)
clients = false       ; per-client group assignments (only useful with groups)

# A gravity rebuild is only needed to apply changed ADLIST *content*; allow/deny
# domains and groups apply on their own. Leave off to let the replica's own
# scheduled gravity cron pick up adlist changes; turn on to apply immediately
# (heavier — downloads + parses every adlist on the replica).
run_gravity = false

# HTTP behaviour
timeout = 8           ; seconds per fast (read/config) request
write_timeout = 60    ; seconds for collection writes — these trigger a list
                      ; reload on the replica and can be slow on constrained hardware
retries = 3           ; attempts per fast request (backoff on 5xx/429/conn)
verify_tls = true     ; set false only for self-signed https Pi-holes

[safety]
# Guards that protect a healthy replica from a glitchy source.
min_hosts = 1         ; refuse to sync if the source reports fewer host records
max_shrink_pct = 50   ; refuse a write that deletes > this % of any collection
                      ; (override for a genuine bulk delete with --force)
shrink_min = 5        ; ...but always allow removing up to this many items, so
                      ; normal edits to a small collection aren't blocked
max_changes = 100     ; refuse > this many collection changes in one run (sanity
                      ; bound on a pathological diff; override with --force)
load_probe_max = 5    ; if a trivial request to a replica is slower than this many
                      ; seconds, the replica is busy: defer gravity-collection
                      ; writes to a later run (DNS-record sync still proceeds)
backup_dir = /var/lib/holesync/backups   ; replica state is saved here before a write
backup_keep = 30      ; rotations to retain per replica

[log]
file = /var/log/holesync.log
level = info          ; debug|info|warning|error
# Default /run/holesync/holesync.lock (created by the systemd unit's
# RuntimeDirectory=, or by holesync itself; falls back to the temp dir if
# unwritable). Kept out of /tmp so a systemd run with PrivateTmp=true and a
# manual CLI run still exclude each other.
lockfile = /run/holesync/holesync.lock
